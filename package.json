{
  "name": "memtrace-workspace",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/web",
    "packages/ts-sdk",
    "packages/mcp-server"
  ],
  "scripts": {
    "test": "bun test packages/ts-sdk/test packages/mcp-server/test packages/vscode-extension/test apps/web/test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "web:dev": "cd apps/web && bun run dev",
    "web:build": "cd apps/web && bun run build",
    "web:test": "cd apps/web && bun run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
