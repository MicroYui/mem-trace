{
  "name": "@memtrace/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for connecting IDE agents to MemTrace through the TypeScript SDK and HTTP API.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    }
  },
  "files": [
    "src"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MicroYui/mem-trace.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/MicroYui/mem-trace#readme",
  "bugs": {
    "url": "https://github.com/MicroYui/mem-trace/issues"
  },
  "keywords": [
    "agent-memory",
    "mcp",
    "memtrace",
    "model-context-protocol",
    "llm-agents"
  ],
  "bin": {
    "memtrace-mcp-server": "./src/server.ts"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "test": "bun test test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@memtrace/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.18.2"
  }
}
